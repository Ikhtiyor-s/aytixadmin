# ===========================================
# AyTiX Admin Panel - Environment Variables
# ===========================================

# API Configuration
# WARNING: Use HTTPS in production for secure communication
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1

# For Production (ALWAYS use HTTPS):
# NEXT_PUBLIC_API_URL=https://api.yourdomain.com/api/v1

# Security Settings
# IMPORTANT: Never commit actual secrets to version control
# Use strong, randomly generated values for production

# Session Configuration (if using server-side sessions)
# SESSION_SECRET=generate-strong-random-secret-here-min-32-chars

# Cookie Settings (for production)
# COOKIE_SECURE=true
# COOKIE_HTTPONLY=true
# COOKIE_SAMESITE=strict

# Rate Limiting (recommended for production)
# RATE_LIMIT_MAX_REQUESTS=100
# RATE_LIMIT_WINDOW_MS=900000

# ===========================================
# SECURITY BEST PRACTICES:
# ===========================================
# 1. Never store passwords or API keys in code
# 2. Use environment-specific .env files (.env.local, .env.production)
# 3. Add .env files to .gitignore (already configured)
# 4. Use HTTPS in production environments
# 5. Implement rate limiting for API endpoints
# 6. Enable CORS only for trusted domains
# 7. Regular security audits and dependency updates
# ===========================================
