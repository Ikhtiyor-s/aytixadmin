# ============================================
# AyTix Admin - Environment Variables
# ============================================
# Bu faylni .env ga nusxalang va qiymatlarni o'zgartiring:
#   cp .env.example .env
# ============================================

# --- PostgreSQL ---
POSTGRES_USER=postgres
POSTGRES_PASSWORD=your_strong_db_password_here
POSTGRES_DB=cursor_market

# --- Backend ---
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
SECRET_KEY=your_secret_key_here_generate_with_openssl_rand_hex_64
DEBUG=false
ALLOW_LOCALHOST=false

# --- Frontend ---
NEXT_PUBLIC_API_URL=/api/v1
API_PROXY_URL=http://backend:8000/api/v1
